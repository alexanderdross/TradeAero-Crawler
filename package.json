{
  "name": "tradeaero-crawler",
  "version": "1.0.0",
  "description": "External marketplace crawler for TradeAero – scrapes aircraft and parts listings from Helmut's UL Seiten",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "crawl:helmut": "tsx src/index.ts --source helmut",
    "crawl:helmut:aircraft": "tsx src/index.ts --source helmut --target aircraft",
    "crawl:helmut:parts": "tsx src/index.ts --source helmut --target parts",
    "crawl:aircraft24": "tsx src/index.ts --source aircraft24",
    "crawl:aeromarkt": "tsx src/index.ts --source aeromarkt",
    "crawl:vereinsflieger": "tsx src/index.ts --source vereinsflieger --target events",
    "crawl:ics": "tsx src/index.ts --source ics --target events",
    "crawl:pilotenausbildung": "tsx src/index.ts --source pilotenausbildung --target events",
    "crawl:fliegermagazin": "tsx src/index.ts --source fliegermagazin --target events",
    "crawl:ulforum": "tsx src/index.ts --source ulforum --target events",
    "crawl:iata": "tsx src/index.ts --source iata --target events",
    "crawl:pilot-frank": "tsx src/index.ts --source pilot-frank --target events",
    "crawl:all": "tsx src/index.ts --source helmut && tsx src/index.ts --source aircraft24 && tsx src/index.ts --source aeromarkt && tsx src/index.ts --source vereinsflieger --target events && tsx src/index.ts --source ics --target events && tsx src/index.ts --source pilotenausbildung --target events && tsx src/index.ts --source fliegermagazin --target events && tsx src/index.ts --source ulforum --target events && tsx src/index.ts --source iata --target events && tsx src/index.ts --source pilot-frank --target events",
    "seed:reference-specs": "tsx src/scripts/seed-reference-specs.ts",
    "seed:ics-calendars": "tsx src/scripts/seed-ics-calendars.ts",
    "seed:eaa-chapters": "tsx src/scripts/seed-eaa-chapter-ics.ts",
    "backfill:structured-data": "tsx src/scripts/backfill-structured-data.ts",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "aviation",
    "crawler",
    "scraper",
    "tradeaero",
    "ultralight"
  ],
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.81.0",
    "@supabase/supabase-js": "^2.49.1",
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.7",
    "https-proxy-agent": "^9.0.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.12.0",
    "eslint": "^9.18.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^3.0.4"
  }
}
