# Master kill switch. Crawler exits immediately unless this is exactly
# "true". The `production` GitHub Environment leaves it unset while
# trade.aero is still gated, so the scheduled crawls don't populate
# tradeaero-prod until public launch. The `main` / dev environment sets
# it to "true" so the refactor.trade.aero DB keeps receiving fresh
# listings.
CRAWLER_ENABLED=false

# Supabase connection (service role key bypasses RLS for backend ingestion)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic API key for Claude Haiku 4.5 translation (all 14 locales)
ANTHROPIC_API_KEY=sk-ant-your-key

# Bright Data proxy (for aircraft24.de and aeromarkt.net)
# Format: http://username:password@brd.superproxy.io:22225
BRIGHT_DATA_PROXY_URL=

# Crawler configuration
CRAWLER_USER_AGENT=TradeAero-Crawler/1.0
CRAWL_DELAY_MS=2000
